# KT-Agent Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

# ── GitHub Configuration ──────────────────────────────────────────────────────
# Personal Access Token with: contents:write
# (issues:write is NOT needed here — GitHub Actions handles that)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Repository in format: owner/repo
GITHUB_REPO=your-org/your-repo-name

# Branch to commit the KT document to
GITHUB_BRANCH=main

# Your GitHub username — embedded in the commit message so the
# review-closed workflow knows who to notify when review is complete.
# Each person who runs the agent sets this to their own GitHub username.
KT_CREATOR=your-github-username

# NOTE: KT_REVIEWER is NOT configured here.
# Set it as a GitHub Actions Variable:
#   Repo → Settings → Secrets and variables → Actions → Variables → New variable
#   Name: KT_REVIEWER   Value: reviewer-github-username
# The reviewer notification is triggered by GitHub Actions AFTER this script
# commits the KT doc — not by this script itself.

# ── AI Configuration (OPTIONAL — not required) ────────────────────────────────
# If set: Claude writes a narrative overview paragraph using your source code.
# If NOT set: a clean static summary is auto-generated from code analysis.
# The rest of the KT document is identical either way.
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
NODE_TLS_REJECT_UNAUTHORIZED=0
